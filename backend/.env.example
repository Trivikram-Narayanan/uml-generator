# ╔══════════════════════════════════════════════════════════════════╗
# ║                    UMLGen  –  .env config                      ║
# ║  Copy to .env and fill in. Only ONE LLM section needed.        ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Security ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-32-byte-hex-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Auth ──────────────────────────────────────────────────────────
# false (default) = no login required, single anonymous user.
# true            = JWT auth enforced on all API endpoints.
REQUIRE_AUTH=false

# ── Database ──────────────────────────────────────────────────────
DB_PATH=data/umlgen.db

# ── Rendering ─────────────────────────────────────────────────────
# Use https://kroki.io (public) or http://localhost:8001 (Docker)
KROKI_URL=https://kroki.io

# ── Generation ────────────────────────────────────────────────────
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.2
LLM_CODE_TEMPERATURE=0.15
LLM_MAX_RETRIES=3

# ── Retrieval ─────────────────────────────────────────────────────
EMBED_MODEL=all-MiniLM-L6-v2
RETRIEVER_TOP_K=6

# ══════════════════════════════════════════════════════════════════
# CHOOSE ONE LLM BACKEND
# ══════════════════════════════════════════════════════════════════

# ── OPTION A: Gemini (cloud, easiest, free tier available) ────────
# Free key: https://aistudio.google.com/apikey
# Models: gemini-2.0-flash | gemini-1.5-pro | gemini-1.5-flash
#
# LLM_BACKEND=gemini
# GEMINI_API_KEY=your-key-here
# GEMINI_MODEL=gemini-2.0-flash

# ── OPTION B: Ollama (local, recommended for privacy) ─────────────
# Install: https://ollama.com  then: ollama pull codellama:7b-code
LLM_BACKEND=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=codellama:7b-code

# ── OPTION C: LM Studio / vLLM / llama.cpp ────────────────────────
# LLM_BACKEND=openai_compat
# OPENAI_COMPAT_URL=http://localhost:1234/v1
# OPENAI_COMPAT_MODEL=codellama-7b-code

# ── OPTION D: HuggingFace in-process (needs 16 GB+ RAM) ───────────
# LLM_BACKEND=transformers
# HF_MODEL_ID=deepseek-ai/deepseek-coder-6.7b-instruct

# ── OPTION E: Mock (UI testing, no model needed) ──────────────────
# LLM_BACKEND=mock

# ── CORS ──────────────────────────────────────────────────────────
# Dev: leave as *
# Prod: set to your actual domain
CORS_ORIGINS=*
# CORS_ORIGINS=https://yourdomain.com
